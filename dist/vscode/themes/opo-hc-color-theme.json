  "tokenColors": [
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.typeof",
        "storage",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#001e4b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.regexp",
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.character",
        "constant.character.escape",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#6f3500"
      }
    },
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.line.double-slash",
        "comment.line.number-sign",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#3e3b35",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.module",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.struct",
        "support.type",
        "support.type.primitive",
        "support.class",
        "meta.type.annotation",
        "entity.name.tag",
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#4f004f"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.method",
        "support.function",
        "meta.function-call",
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator",
        "variable.function"
      ],
      "settings": {
        "foreground": "#004c46"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#353f4a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#13191f"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#001e4b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#003c88"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#004c46",
    "function.declaration": "#004c46",
    "method": "#004c46",
    "type": "#4f004f",
    "class": "#4f004f",
    "interface": "#4f004f",
    "enum": "#4f004f",
    "namespace": "#4f004f",
    "typeParameter": "#4f004f",
    "variable": "#13191f",
    "parameter": "#13191f",
    "property": "#13191f",
    "enumMember": "#6f3500",
    "decorator": "#004c46"
  }
}