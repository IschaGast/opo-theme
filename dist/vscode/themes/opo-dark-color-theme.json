  "tokenColors": [
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.typeof",
        "storage",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#bad6ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.regexp",
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.character",
        "constant.character.escape",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ea8d4a"
      }
    },
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.line.double-slash",
        "comment.line.number-sign",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#b8b4ae",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.module",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.struct",
        "support.type",
        "support.type.primitive",
        "support.class",
        "meta.type.annotation",
        "entity.name.tag",
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#eea8ec"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.method",
        "support.function",
        "meta.function-call",
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator",
        "variable.function"
      ],
      "settings": {
        "foreground": "#58c3b6"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#99a3ae"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d1d7df"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#bad6ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#79afff"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#58c3b6",
    "function.declaration": "#58c3b6",
    "method": "#58c3b6",
    "type": "#eea8ec",
    "class": "#eea8ec",
    "interface": "#eea8ec",
    "enum": "#eea8ec",
    "namespace": "#eea8ec",
    "typeParameter": "#eea8ec",
    "variable": "#d1d7df",
    "parameter": "#d1d7df",
    "property": "#d1d7df",
    "enumMember": "#ea8d4a",
    "decorator": "#58c3b6"
  }
}