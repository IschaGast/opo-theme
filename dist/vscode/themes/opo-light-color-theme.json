    "terminal.ansiWhite": "#eeeae2",
    "terminal.ansiBrightBlack": "#11161d",
    "terminal.ansiBrightRed": "#844000",
    "terminal.ansiBrightGreen": "#005a52",
    "terminal.ansiBrightYellow": "#704e00",
    "terminal.ansiBrightBlue": "#001f4d",
    "terminal.ansiBrightMagenta": "#550855",
    "terminal.ansiBrightCyan": "#00489f",
    "terminal.ansiBrightWhite": "#d4d0c6",
